{
  "gateway": {
    "mode": "local",
    "auth": {
      "enabled": true,
      "token": "__REPLACE_GATEWAY_TOKEN__"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "__REPLACE_BASE_URL__",
        "api": "openai-completions",
        "apiKey": "__REPLACE_OPENAI_API_KEY__",
        "models": [
          {
            "id": "__REPLACE_MODEL_ID_PRIMARY__",
            "name": "__REPLACE_MODEL_NAME_PRIMARY__"
          },
          {
            "id": "__REPLACE_MODEL_ID_FALLBACK_1__",
            "name": "__REPLACE_MODEL_NAME_FALLBACK_1__"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/__REPLACE_MODEL_ID_PRIMARY__",
        "fallbacks": [
          "openai/__REPLACE_MODEL_ID_FALLBACK_1__"
        ]
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "domain": "feishu",
      "connectionMode": "websocket",
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "accounts": {
        "default": {
          "appId": "__REPLACE_FEISHU_APP_ID__",
          "appSecret": "__REPLACE_FEISHU_APP_SECRET__"
        }
      }
    }
  }
}
