# OpenClaw runtime env example (no secrets in git)
# 说明：核心 API/模型/渠道配置统一写入 ~/.openclaw/openclaw.json（见 docs/config-reference.md）。
# 本文件仅保留运行时基础环境变量。

NODE_ENV=production
PORT=3030
OPENCLAW_DATA_DIR=/Users/svc_openclaw/var/openclaw
OPENCLAW_LOG_DIR=/Users/svc_openclaw/logs/openclaw

# Optional runtime hints
# HOME=/Users/svc_openclaw
# PATH=/Users/svc_openclaw/.local/npm/bin:/usr/local/bin:/usr/bin:/bin
